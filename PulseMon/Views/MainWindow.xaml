<Window x:Class="PulseMon.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="PulseMon"
        Width="420" Height="360"
        MinWidth="320" MinHeight="280"
        WindowStyle="None"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="CanResize"
        Topmost="{Binding IsAlwaysOnTop}"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource SurfaceBorderBrush}"
            BorderThickness="1">
        <DockPanel>

            <!-- Tilpasset titellinje -->
            <Grid DockPanel.Dock="Top"
                  Height="36"
                  Background="{StaticResource TitleBarBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App-titel + ikon -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentCpuBrush}" Margin="0,0,6,0"/>
                    <TextBlock Text="PulseMon"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Heartbeat grafik -->
                <Viewbox Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                         Height="16" IsHitTestVisible="False">
                    <Path Data="M 0,12 H 12 L 14,9 L 16,12 H 24 L 26,15 L 28,1 L 30,19 L 32,12 H 40 L 42,7 L 46,7 L 48,12 H 80"
                          Stroke="#4FC3F7" StrokeThickness="1.8"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Fill="Transparent"/>
                </Viewbox>

                <!-- Knapper -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <ToggleButton Style="{StaticResource PinButtonStyle}"
                                  IsChecked="{Binding IsAutoScale}"
                                  ToolTip="Auto-skala: tilpas Y-akse til faktisk dataniveau">
                        <TextBlock Text="⇅" FontSize="12"/>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource PinButtonStyle}"
                                  IsChecked="{Binding IsAlwaysOnTop}"
                                  ToolTip="Hold øverst">
                        <TextBlock Text="📌" FontSize="11"/>
                    </ToggleButton>
                    <Button Style="{StaticResource CloseButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Luk">
                        <TextBlock Text="✕" FontSize="11"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Hoved-indhold -->
            <Grid Margin="12,10,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- CPU header -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="CPU BRUG"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="10"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding CpuLabel}"
                               Foreground="{StaticResource AccentCpuBrush}"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- CPU graf -->
                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6"
                        Margin="0,4,0,0"
                        BorderBrush="{StaticResource SurfaceBorderBrush}"
                        BorderThickness="1">
                    <ScottPlot:WpfPlot x:Name="CpuPlot" Margin="0"/>
                </Border>

                <!-- Separator -->
                <Rectangle Grid.Row="2" Height="1" Fill="{StaticResource SurfaceBorderBrush}" Margin="0,10,0,0"/>

                <!-- GPU header -->
                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="GPU BRUG"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="10"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding GpuLabel}"
                               Foreground="{StaticResource AccentGpuBrush}"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- GPU graf -->
                <Border Grid.Row="4"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6"
                        Margin="0,4,0,0"
                        BorderBrush="{StaticResource SurfaceBorderBrush}"
                        BorderThickness="1">
                    <ScottPlot:WpfPlot x:Name="GpuPlot" Margin="0"/>
                </Border>
            </Grid>

        </DockPanel>
    </Border>
</Window>
